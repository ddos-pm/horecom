{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "prisma migrate deploy && prisma generate && next build",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 4 * * *"
    }
  ]
}
