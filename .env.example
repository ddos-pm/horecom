# Horecom — environment variables template
# Copy to .env.local and fill in. .env.local is gitignored.
# Last sync with code: 2026-06-03 (audit-driven refresh).

# === Supabase (DB + Auth) ===
# Direct connection — used for migrations (port 5432, session pooler in Supabase)
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"
# Transaction pooler — used at runtime (port 6543, pgbouncer mode)
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# === Next.js / Supabase Auth ===
AUTH_SECRET="generate-with: openssl rand -base64 32"
# Base URL of the deployment. Used for absolute URLs in JSON-LD, MCP
# manifest, sitemap, emails. Set per-deployment (preview vs prod).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Optional override read by lib/base-url.ts when NEXT_PUBLIC_BASE_URL
# isn't set. Useful if NEXT_PUBLIC_BASE_URL is reserved for the canary.
NEXT_PUBLIC_SITE_URL=""

# === Error monitoring (Sentry) ===
# Create project at https://sentry.io → settings → DSN
# Public DSN exposed to browser; server reads either NEXT_PUBLIC_ or SENTRY_DSN
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Required only in CI for source-map upload (skipped if absent)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# === AI ===
# For scripts/enrich-products.ts (Claude product enrichment)
ANTHROPIC_API_KEY="sk-ant-..."
# Optional override; defaults to claude-sonnet-4-5
# ANTHROPIC_MODEL="claude-sonnet-4-5"
# For scripts/generate-product-embeddings.ts (OpenAI text-embedding-3-small)
OPENAI_API_KEY="sk-..."

# === Integrations ===

# WhatsApp Business API (360dialog) — used by lib/dialog360.ts for OTP
# login + order-flow templates. Without D360_API_KEY the lib runs in
# stub mode (logs + returns fake message ids). Submit templates via the
# 360dialog dashboard per docs/40-whatsapp-templates-submission.md.
D360_API_KEY=""
# Optional override; defaults to the 360dialog Cloud API v1 endpoint.
# D360_API_BASE="https://waba.360dialog.io/v1"
# Public-facing phone number (E.164 without the leading +). Used in
# MCP create_draft_order so the WhatsApp deep-link reaches the right
# inbox. Same number that 360dialog onboarded.
WHATSAPP_PHONE_NUMBER="77078607779"

# Kaspi Pay Business API — used by lib/kaspi.ts for invoice + webhook.
# Without KASPI_API_KEY + KASPI_MERCHANT_ID the lib runs in stub mode
# (returns a fake URL prefixed STUB-) so dev/preview flows can be
# exercised end-to-end.
KASPI_API_KEY=""
KASPI_MERCHANT_ID=""
# Optional override; defaults to Kaspi's documented v3 endpoint.
# KASPI_API_BASE="https://kaspi.kz/api/v3/payment"
# HMAC-SHA256 secret used by /api/payments/kaspi/webhook to verify
# inbound payment-status pushes. Without it, prod rejects all webhooks
# (safer default); dev/preview accept any signature so stub flows
# stay testable. Generate: openssl rand -hex 32
KASPI_WEBHOOK_SECRET=""

# AmoCRM — when all four are populated, new orders auto-push to the
# pipeline via lib/amocrm.ts → pushOrderToAmoCRM. Missing any value =
# no-op (logged), order creation still succeeds.
AMOCRM_SUBDOMAIN=""               # e.g. "horecom" (for horecom.amocrm.ru)
AMOCRM_LONG_LIVED_TOKEN=""        # Settings → Integrations → Profile
AMOCRM_PIPELINE_ID=""             # numeric, the "Заказы" pipeline
AMOCRM_STAGE_NEW_ORDER=""         # numeric, "Новый заказ" stage
# Optional — set to populate custom fields on the lead instead of dumping
# everything into the lead name. Numeric custom-field ids from Amo.
AMOCRM_FIELD_ORDER_NUMBER=""
AMOCRM_FIELD_DELIVERY_DATE=""
AMOCRM_FIELD_ITEMS=""
# Shared secret for the inbound /api/amocrm/webhook endpoint. Without it
# set, the endpoint accepts everything (useful for first-time Amo trigger
# config testing). Once Amo is sending real "lead status changed" events,
# set this and configure Amo to include it via Authorization: Bearer X,
# X-Webhook-Secret header, or ?token= query string.
# Generate: openssl rand -hex 32
AMOCRM_WEBHOOK_SECRET=""

# Email — Resend (lib/email.ts). RESEND_API_KEY missing → stub mode
# (console.logs the would-be email). Production sends customer order
# confirmation in their locale + manager copy in Russian.
RESEND_API_KEY=""
# Optional — override sender domain (default "Horecom <orders@horecom.kz>")
# RESEND_FROM="Horecom <orders@horecom.kz>"
# Optional — override manager copy recipient (default Horecomkz@gmail.com)
# RESEND_MANAGER=""

# === Cron auth ===
# Vercel Cron invokes /api/cron/subscription-reminders with
# Authorization: Bearer <CRON_SECRET>. Without the value set, the
# route accepts any caller (dev/preview convenience). In prod ALWAYS
# set this to a long random value. Generate: openssl rand -hex 32
CRON_SECRET=""

# === Rate limiting + OTP store (lib/ratelimit.ts + lib/otp-store.ts) ===
# Upstash Redis REST endpoint + token. Required for:
#   • /api/amocrm/webhook rate limit
#   • /api/orders + /api/payments/kaspi/invoice rate limit
#   • OTP challenge store (cross-instance, 5-min TTL)
#   • /api/mcp/* rate limit
# Without values → permissive no-op for rate limits (allow all) and
# in-memory OTP store (single-instance only, warns at first use).
# Sign up: https://console.upstash.com → Create Redis → copy REST URL + TOKEN.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
