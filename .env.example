# Horecom — environment variables template
# Copy to .env.local and fill in. .env.local is gitignored.

# === Supabase (DB + Auth) ===
# Direct connection — used for migrations (port 5432, session pooler in Supabase)
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"
# Transaction pooler — used at runtime (port 6543, pgbouncer mode)
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# === Next.js / Supabase Auth ===
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# === AI ===
# For scripts/enrich-products.ts (Claude product enrichment)
ANTHROPIC_API_KEY="sk-ant-..."
# Optional override; defaults to claude-sonnet-4-5
# ANTHROPIC_MODEL="claude-sonnet-4-5"

# For scripts/generate-product-embeddings.ts (OpenAI text-embedding-3-small)
OPENAI_API_KEY="sk-..."

# === Error monitoring (Sentry) ===
# Create project at https://sentry.io → settings → DSN
# Public DSN exposed to browser; server reads either NEXT_PUBLIC_ or SENTRY_DSN
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Required only in CI for source-map upload (skipped if absent)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# === Integrations (V1 — when external approvals land) ===
# WhatsApp Business API (360dialog) — V1
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER="77078607779"
# Kaspi Pay Business API — V1
KASPI_API_KEY=""
KASPI_MERCHANT_ID=""
# AmoCRM — V1
AMOCRM_DOMAIN=""
AMOCRM_ACCESS_TOKEN=""
AMOCRM_REFRESH_TOKEN=""
# Cloudinary — when migrating off Tilda CDN
CLOUDINARY_CLOUD_NAME="horecom"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
