# Database (Neon Postgres recommended)
# Get connection string at https://console.neon.tech
DATABASE_URL="postgresql://user:password@host:5432/horecom?sslmode=require"

# Auth (NextAuth.js v5)
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# WhatsApp Business API (360dialog)
WHATSAPP_API_KEY="your-360dialog-api-key"
WHATSAPP_PHONE_NUMBER="77078607779"

# Kaspi Pay Business API
KASPI_API_KEY="your-kaspi-business-api-key"
KASPI_MERCHANT_ID="your-merchant-id"

# AmoCRM
AMOCRM_DOMAIN="your-account.amocrm.ru"
AMOCRM_ACCESS_TOKEN="your-access-token"
AMOCRM_REFRESH_TOKEN="your-refresh-token"

# Analytics + Monitoring
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
SENTRY_DSN="https://your-sentry-dsn.ingest.sentry.io/project-id"

# IndexNow (for AI/search indexing)
INDEXNOW_KEY="generate-32-char-random-string"

# Public environment
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Storage (Cloudinary recommended for product images)
CLOUDINARY_CLOUD_NAME="horecom"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
